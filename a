local FarmTab = Window:CreateTab("오토팜 (Auto Farm)", 4483362458)
local FarmSection = FarmTab:CreateSection("농장 기능")

-- 전역 변수 설정
local AutoFarmEnabled = false
local FarmDelay = 1

-- 오토팜 토글
local AutoFarmToggle = FarmTab:CreateToggle({
    Name = "자동 고기 파밍 켜기",
    CurrentValue = false,
    Flag = "AutoFarmToggle",
    Callback = function(Value)
        AutoFarmEnabled = Value
        
        if AutoFarmEnabled then
            Rayfield:Notify({
                Title = "활성화",
                Content = "오토팜이 시작되었습니다.",
                Duration = 3,
                Image = 4483362458
            })
            
            task.spawn(function()
                local lp = game.Players.LocalPlayer
                
                while AutoFarmEnabled do
                    -- 1단계: 파밍 위치로 이동
                    if lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(-60.26, 4.70, -61.24))
                        task.wait(0.5) -- 순간이동 후 위치 고정 대기
                    end

                    -- 2단계: 모바일/PC 상관없이 '음식 잡기' 상호작용 강제 실행 (광클 방식)
                    print("[AutoFarm] 음식 잡기 시도 중...")
                    local function interactWithFood()
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("ProximityPrompt") and (v.ObjectText == "음식 잡기" or v.ActionText == "음식 잡기") then
                                fireproximityprompt(v)
                                return true
                            end
                        end
                        return false
                    end

                    -- 최대 15초 동안 음식 잡기 시도 (인벤토리가 가득 찰 때까지)
                    local startTime = tick()
                    while AutoFarmEnabled and (tick() - startTime) < 15 do
                        interactWithFood()
                        task.wait(0.2) -- 0.2초 간격으로 연속 클릭/실행
                    end

                    -- 3단계: 고기 먹기 위치로 이동
                    if AutoFarmEnabled and lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(-12.36, 4.68, -64.56))
                        task.wait(0.5)
                    end

                    -- 4단계: 먹기 상호작용 실행 후, 먹는 시간(7초) 동안 제자리 고정
                    print("[AutoFarm] 고기 먹는 중...")
                    local function interactWithEat()
                        for _, v in pairs(workspace:GetDescendants()) do
                            if v:IsA("ProximityPrompt") and (v.ObjectText == "먹기" or v.ActionText == "먹기") then
                                fireproximityprompt(v)
                                return true
                            end
                        end
                        return false
                    end

                    interactWithEat()

                    -- 고기를 다 먹을 때까지(일어날 때까지) 대기하여 무한 텔레포트 방지
                    local eatDuration = 7
                    local eatStartTime = tick()
                    while AutoFarmEnabled and (tick() - eatStartTime) < eatDuration do
                        task.wait(1)
                    end

                    -- 5단계: 설정된 지연 시간(슬라이더) 적용
                    if AutoFarmEnabled then
                        task.wait(FarmDelay)
                    end
                end
            end)
        else
            Rayfield:Notify({
                Title = "비활성화",
                Content = "오토팜이 중지되었습니다.",
                Duration = 3,
                Image = 4483362458
            })
        end
    end
})

