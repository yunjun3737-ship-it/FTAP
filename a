-- 중복 실행 방지: 이전에 켜져 있던 UI가 있다면 제거
if getgenv().RayfieldWindows then
    for _, win in pairs(getgenv().RayfieldWindows) do
        win:Destroy() -- 기존 창 파괴
    end
    getgenv().RayfieldWindows = {}
else
    getgenv().RayfieldWindows = {}
end

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "감옥 펌프 오토팜 (Prison Farm)",
    LoadingTitle = "Alpaca's Script Interface",
    LoadingSubtitle = "by Alpaca", -- 제작자 이름 변경
    ConfigurationSaving = {
        Enabled = true,
        FolderName = nil, 
        FileName = "PrisonFarmConfig"
    },
    Discord = {
        Enabled = false,
        Invite = "noinvitelink",
        RememberJoins = true
    },
    KeySystem = true,
    KeySettings = {
        Title = "알파 허브 입니다",
        Subtitle = "Key System",
        Note = "No method of obtaining the key is provided",
        FileName = "키",
        SaveKey = true,
        GrabKeyFromSite = false,
        Key = {"알파카"}
    }
})

table.insert(getgenv().RayfieldWindows, Window)

-- 메인 탭 생성
local FarmTab = Window:CreateTab("오토팜 (Auto Farm)", 4483362458)
local FarmSection = FarmTab:CreateSection("농장 기능")

-- 오토팜 토글 (기능 제외)
local AutoFarmToggle = FarmTab:CreateToggle({
    Name = "자동 고기 파밍 켜기",
    CurrentValue = false,
    Flag = "AutoFarmToggle",
    Callback = function(Value)
        if Value then
            print("오토팜이 활성화되었습니다.")
        else
            print("오토팜이 비활성화되었습니다.")
        end
    end
})

-- 슬라이더 추가
local FarmSpeedSlider = FarmTab:CreateSlider({
    Name = "파밍 지연 시간 (초)",
    Range = {0.1, 5},
    Increment = 0.1,
    Suffix = "s",
    CurrentValue = 1,
    Flag = "FarmSlider",
    Callback = function(Value)
        print("지연 시간이 " .. Value .. "초로 변경되었습니다.")
    end
})

