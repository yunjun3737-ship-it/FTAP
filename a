        FileName = "키",
        SaveKey = true,
        GrabKeyFromSite = false,
        Key = {"알파카"}
    }
})

table.insert(getgenv().RayfieldWindows, Window)

-- 메인 탭 생성
local FarmTab = Window:CreateTab("오토팜", 4483362458)
local FarmSection = FarmTab:CreateSection("농장 기능")

-- 변수 정의
local AutoFarmEnabled = false
local FarmDelay = 1 -- 기본 지연 시간

local AutoFarmToggle = FarmTab:CreateToggle({
    Name = "고기 오토팜",
    CurrentValue = false,
    Flag = "AutoFarmToggle",
    Callback = function(Value)
        AutoFarmEnabled = Value
        
        if AutoFarmEnabled then
            Rayfield:Notify({
                Title = "활성화",
                Content = "오토팜이 시작되었습니다.",
                Duration = 3,
                Image = 4483362458
            })
            
            task.spawn(function()
                local lp = game.Players.LocalPlayer
                
                while AutoFarmEnabled do
                    -- 1. 파밍 위치로 순간이동 (지연 없음)
                    if lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(-60.26, 4.70, -61.24))
                        task.wait(0.2) -- 위치 고정용 짧은 대기
                    end

                    -- 2. 고기 획득 버튼(ClickDetector 또는 RemoteEvent) 광클
                    -- 본인의 게임 내 오브젝트/위치에 맞게 주석을 해제하고 경로를 맞춰주세요.
                    print("[AutoFarm] 고기 획득 시도 중...")
                    local farmingTimeout = tick() + 10 -- 무한 루프 방지용 타임아웃 (최대 10초)
                    
                    while AutoFarmEnabled do
                        -- 고기가 가득 찼는지 확인하는 조건 (게임 내 메시지나 인벤토리 상태에 맞게 수정 필요)
                        -- 예: if 가득참 then break end
                        
                        -- 광클 예시:
                        -- fireclickdetector(game:GetService("Workspace").FoodButton.ClickDetector)
                        -- 또는
                        -- game:GetService("ReplicatedStorage").RemoteEvent:FireServer("GetMeat")
                        
                        task.wait(0.1) -- 광클 간격
                        
                        -- 타임아웃 도달 시 탈출
                        if tick() >= farmingTimeout then
                            warn("[AutoFarm] 파밍 시간 초과로 다음 단계로 이동합니다.")
                            break
                        end
                    end

                    -- 3. 고기 먹기 위치로 이동
                    if AutoFarmEnabled and lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(-12.36, 4.68, -64.56))
                        task.wait(0.2)
                    end

                
                    print("[AutoFarm] 고기 먹는 중...")
                    
                    local eatDuration = 5 -- 먹는 시간 (초, 게임에 맞게 조절하세요)
                    local startTime = tick()
                    
                    while AutoFarmEnabled and (tick() - startTime) < eatDuration do
                        task.wait(1)
                    end

                    -- 5. 설정된 지연 시간 적용
                    if AutoFarmEnabled then
                        task.wait(FarmDelay)
                    end
                end
            end)
        else
            Rayfield:Notify({
                Title = "비활성화",
                Content = "오토팜이 중지되었습니다.",
                Duration = 3,
                Image = 4483362458
            })
        end
    end
})


