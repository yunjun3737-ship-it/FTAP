-- 메인 탭 생성
local FarmTab = Window:CreateTab("오토팜 (Auto Farm)", 4483362458)
local FarmSection = FarmTab:CreateSection("농장 기능")

-- 변수 정의
local AutoFarmEnabled = false
local FarmDelay = 1 -- 기본 지연 시간

-- 오토팜 토글
local AutoFarmToggle = FarmTab:CreateToggle({
    Name = "자동 고기 파밍 켜기",
    CurrentValue = false,
    Flag = "AutoFarmToggle",
    Callback = function(Value)
        AutoFarmEnabled = Value
        
        if AutoFarmEnabled then
            Rayfield:Notify({
                Title = "활성화",
                Content = "오토팜이 시작되었습니다.",
                Duration = 3,
                Image = 4483362458
            })
            
            -- 비동기 루프 실행
            task.spawn(function()
                local lp = game.Players.LocalPlayer
                
                while AutoFarmEnabled do
                    -- 1. 파밍 위치로 이동
                    if lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(-60.26, 4.70, -61.24))
                        task.wait(0.2) -- 텔레포트 후 위치 고정을 위한 대기
                    end

                    -- 파밍 진행 (버튼 상호작용 시뮬레이션 등)
                    -- 여기에 실제 고기를 획득하는 함수나 원격 이벤트를 추가할 수 있습니다.
                    -- 예시: fireclickdetector(game:GetService("Workspace")....ClickDetector)
                    print("[AutoFarm] 고기 파밍 중... 획득 대기 중...")
                    
                    -- 고기가 가득 찼는지(또는 파밍이 끝났는지) 확인하는 조건
                    -- 예시로 5초간 파밍한다고 가정하며, 필요에 맞게 수정하세요.
                    local maxWait = 5
                    local timer = 0
                    while AutoFarmEnabled and timer < maxWait do
                        task.wait(1)
                        timer = timer + 1
                    end

                    -- 2. 고기 먹기 위치로 이동
                    if AutoFarmEnabled and lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                        lp.Character.HumanoidRootPart.CFrame = CFrame.new(Vector3.new(-12.36, 4.68, -64.56))
                        task.wait(0.2)
                    end

                    -- 고기 먹기 진행
                    print("[AutoFarm] 고기 먹는 중...")
                    -- 먹는 동안 캐릭터가 멈춰있도록 대기
                    local eatDuration = 5 -- 먹는 시간 (초)
                    task.wait(eatDuration)

                    -- 3. 설정된 지연 시간 대기 (사용자가 지정한 슬라이더 시간 적용)
                    if AutoFarmEnabled then
                        task.wait(FarmDelay)
                    end
                end
            end)
        else
            Rayfield:Notify({
                Title = "비활성화",
                Content = "오토팜이 중지되었습니다.",
                Duration = 3,
                Image = 4483362458
            })
        end
    end
})

